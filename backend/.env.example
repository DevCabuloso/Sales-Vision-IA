# ─── Servidor ───
NODE_ENV=development
PORT=3000
# 127.0.0.1 por padrão (só acessível via proxy no mesmo host, ex.: nginx).
# Use 0.0.0.0 só se o proxy reverso rodar num host/container diferente.
HOST=127.0.0.1
FRONTEND_URL=http://localhost:5173
# URL pública do próprio backend — usada para montar a webhook_url registrada
# na Evolution API (ex: https://api.seudominio.com). Em dev, o default
# (http://localhost:PORT) já funciona.
BACKEND_URL=

# ─── Supabase (backend = service_role) ───
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
# bucket usado para mídia de chat/broadcast (padrão: chat-media)
SUPABASE_MEDIA_BUCKET=chat-media
# opcional (ferramentas externas)
DATABASE_URL=
DB_SSL=true

# ─── Segurança ───
JWT_SECRET=troque-este-segredo-bem-longo
JWT_EXPIRES_IN=7d
# openssl rand -hex 32
ENCRYPTION_KEY=

# ─── OpenAI ───
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Teto de segurança contra custo de IA descontrolado (mensagens de IA por
# tenant por dia) — NÃO é limite de plano/cobrança. 0 desativa.
AI_DAILY_MESSAGE_CAP=2000

# ─── Google Calendar (OAuth) ───
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback

# ─── Meta WhatsApp (WhatsApp Cloud API oficial) ───
META_GRAPH_VERSION=v21.0
META_WEBHOOK_VERIFY_TOKEN=sdr-verify
# Assinatura HMAC dos webhooks da Meta — OBRIGATÓRIO configurar antes de
# ativar essa integração para o primeiro tenant. Em produção
# (NODE_ENV=production), sem esta variável o webhook recusa (403) TODAS as
# requisições em vez de aceitar sem checar (fail-closed).
META_APP_SECRET=

# ─── Evolution API (gateway WhatsApp self-hosted) ───
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
# Segredo global de fallback validado pelo webhook enquanto um canal ainda
# não tem segredo próprio (gerado automaticamente ao rodar
# "Revalidar Webhook" na tela de Canais — ver utils/channelWebhookSecret.js).
# Também obrigatório em produção pelo mesmo motivo do META_APP_SECRET acima.
EVOLUTION_WEBHOOK_SECRET=

# ─── InfinitePay (checkout do teste grátis) ───
# @handle da InfiniteTag, sem o "$" (ex: se seu link é $minhaempresa, use minhaempresa)
INFINITEPAY_HANDLE=
TRIAL_PLAN_TIER=pro
TRIAL_PLAN_PRICE_CENTS=39700
TRIAL_DAYS=7

# ─── SMTP (relatório semanal por e-mail) ───
# Sem SMTP_HOST, o envio vira um no-op logado — a feature fica pronta no
# código, mas só envia de verdade com credenciais reais (Gmail com senha de
# app, SendGrid, Resend, etc.) — ver services/email.js.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
