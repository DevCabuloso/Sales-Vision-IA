{
  "name": "sdr-platform",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --names \"BACK,FRONT\" --prefix-colors \"cyan,magenta\" \"cd /d backend && node node_modules/nodemon/bin/nodemon.js src/server.js\" \"cd /d frontend && node node_modules/vite/bin/vite.js\"",
    "dev:back": "npm run dev --prefix backend",
    "dev:front": "npm run dev --prefix frontend",
    "test": "npm run test --prefix backend",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "concurrently": "^9.1.2",
    "wait-on": "^9.0.10"
  }
}
